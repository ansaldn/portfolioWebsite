# Template for required environment variables. Copy to `.env` and fill in.
# `.env` is gitignored; `.env.example` is committed so collaborators / future-you
# know which keys are required without exposing the real values.
#
# All VITE_* values are embedded into the public client bundle at build time,
# so only ever put PUBLIC identifiers here — never secrets or API keys that
# must stay server-side. (Turnstile *site* keys and Auth0 *client* IDs are
# public by design; their matching secret keys are not and live elsewhere.)

# Auth0 SPA application — public identifiers (safe to share).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# Formspree endpoint for the contact + engagement forms. If empty, the contact
# form falls back to a mailto: link and the engage form still lets verified
# humans reach the calendar. https://formspree.io
VITE_FORMSPREE_ENDPOINT=

# Cloudflare Turnstile SITE key (public). Protects the engagement form.
# If empty, the app falls back to Cloudflare's "always passes" TEST key so the
# flow is demoable, and shows a notice. Get a real key (free) at:
# https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=

# Google Calendar appointment-schedule embed URL. Create an appointment
# schedule in Google Calendar, open "Share" → "Embed", and paste the iframe
# src here (it looks like the URL below). If empty, the booking step shows a
# friendly fallback with a mailto link instead.
# https://calendar.google.com/calendar/appointments/schedules/AcZ...?gv=true
VITE_GCAL_EMBED_URL=
