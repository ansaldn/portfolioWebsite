# Template for required environment variables. Copy to `.env` and fill in.
# `.env` is gitignored; `.env.example` is committed so collaborators / future-you
# know which keys are required without exposing the real values.

# Auth0 SPA application — public identifiers (safe to share).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# Formspree endpoint for the contact form. If empty, the form falls back
# to a mailto: link. https://formspree.io
VITE_FORMSPREE_ENDPOINT=
